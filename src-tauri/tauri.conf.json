{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "NanChat",
  "version": "1.2.0",
  "identifier": "com.nanchat.app",
  "build": {
    "frontendDist": "../dist",
    "beforeDevCommand": "",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "NanChat",
        "resizable": true,
        "maximized": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https://api.nanchat.com https://api.nanexplorer.com https://proxy.xno.link https://proxy-signature.xno.link https://cdn.moneyconvert.net https://link-preview.b3nskalz.workers.dev https://nanswap.com wss://nodes.nanswap.com wss://api.nanchat.com https://*.googleapis.com https://*.firebaseapp.com https://*.firebasestorage.app; frame-src 'self' https://*.firebaseapp.com; object-src 'none'"
    }
  },
  "bundle": {
    "publisher": "YXSE SAS",
    "createUpdaterArtifacts": true,
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "./Entitlements.plist"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "nano",
          "web-nano",
          "ban",
          "nanauth",
          "nan",
          "xdg"
        ]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQzRkY1QjE3OTNCMUI3ODMKUldTRHQ3R1RGMXYvMHhJb21sSjV2VVdxS1NuWnd3dEs1Z21HVWFpR3FwS0N4RmJ4RUtrOUZKeW0K",
      "endpoints": [
        "https://github.com/yxse/nanchat/releases/latest/download/latest.json"
      ]
    }
  }
}
