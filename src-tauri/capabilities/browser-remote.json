{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "browser-remote",
  "description": "allows remote pages in browser webviews to open URLs",
  "windows": [
    "browser-*"
  ],
  "remote": {
    "urls": [
      "https://*"
    ]
  },
  "permissions": [
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "https://*" }]
    }
  ]
}
